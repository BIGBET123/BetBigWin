// Payment Functions
function selectAmount(amount) {
    document.getElementById('custom-amount').value = amount;
    updatePaymentSummary(amount);
}

function updatePaymentSummary(amount) {
    const fee = amount * 0.01; // 1% fee example
    const total = parseFloat(amount) + parseFloat(fee);
    
    document.getElementById('summary-amount').textContent = 'GH₵ ' + parseFloat(amount).toFixed(2);
    document.getElementById('summary-fee').textContent = 'GH₵ ' + fee.toFixed(2);
    document.getElementById('summary-total').textContent = 'GH₵ ' + total.toFixed(2);
}

function proceedToPayment() {
    const amount = document.getElementById('custom-amount').value;
    
    if (!amount) {
        alert('Please enter an amount');
        return;
    }
    
    // Here you would integrate with Paystack
    alert('Processing payment of GH₵' + amount);
}

